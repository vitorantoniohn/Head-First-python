from random import randint
secret = randint(1,10)

print("Welcome to the exam program!")
guess = 0
while guess != secret:
  g = input("Guess a number")
  guess = int(g)
  if guess > secret:
    print("Too high, try again!")
  else:
    if guess < secret:
      print("Too low, try again!")
    else:
      print("Too low, try again!")
print("Game Over")
  